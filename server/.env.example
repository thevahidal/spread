# Spread backend configuration. Copy to `.env` and fill in, or export these
# in your shell before `npm start`. (This file is just an example.)

# Comma-separated Google OAuth client IDs you accept tokens for. Add the iOS,
# Android, and Web client IDs you created in the Google Cloud Console.
GOOGLE_CLIENT_IDS=

# Comma-separated Apple audiences. For native "Sign in with Apple" this is your
# app's bundle identifier (must match app.json → ios.bundleIdentifier, e.g.
# com.spread.app).
APPLE_CLIENT_IDS=com.spread.app

# Set to 1 to enable the local developer login (POST /api/auth/dev). Leave unset
# in production — it lets anyone sign in with just an email.
SPREAD_DEV_AUTH=

# Port the API listens on (default 4000).
PORT=4000
