# Spread app configuration. Copy to `.env` (Expo loads EXPO_PUBLIC_* vars
# automatically). Restart `npm start` after changing these.

# Backend URL. Leave unset to auto-detect: localhost on web/simulator, or the
# Expo dev-server LAN host on a physical phone. Set explicitly for production.
# EXPO_PUBLIC_API_URL=https://api.example.com

# Google OAuth client IDs (from the Google Cloud Console → Credentials).
# These are public client identifiers, not secrets.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Set to 1 to show the local developer login on the sign-in screen. Must be
# paired with SPREAD_DEV_AUTH=1 on the backend.
EXPO_PUBLIC_DEV_AUTH=
